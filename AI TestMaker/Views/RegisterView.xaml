<UserControl x:Class="AI_TestMaker.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0B1020">

    <UserControl.LayoutTransform>
        <ScaleTransform x:Name="LocalZoom" ScaleX="1" ScaleY="1"/>
    </UserControl.LayoutTransform>

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">

        <Border Background="#141B2F"
                Padding="30"
                CornerRadius="12"
                Width="380">

            <StackPanel>

                <TextBlock Text="Crear cuenta"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#5FA8FF"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 25"/>

                <!-- Usuario -->
                <TextBlock Text="Usuario"
                           Foreground="#B0C4DE"
                           Margin="0 0 0 4"/>
                <TextBox x:Name="TxtUser"
                         Height="35"
                         Background="White"
                         Foreground="Black"
                         BorderBrush="#3A7BD5"
                         BorderThickness="1"
                         Padding="6"
                         Margin="0 0 0 12"/>

                <!-- Contraseña -->
                <TextBlock Text="Contraseña"
                           Foreground="#B0C4DE"
                           Margin="0 0 0 4"/>
                <PasswordBox x:Name="TxtPass"
                             Height="35"
                             Background="White"
                             Foreground="Black"
                             BorderBrush="#3A7BD5"
                             BorderThickness="1"
                             Padding="6"
                             Margin="0 0 0 12"/>

                <!-- Confirmar contraseña -->
                <TextBlock Text="Confirmar contraseña"
                           Foreground="#B0C4DE"
                           Margin="0 0 0 4"/>
                <PasswordBox x:Name="TxtPass2"
                             Height="35"
                             Background="White"
                             Foreground="Black"
                             BorderBrush="#3A7BD5"
                             BorderThickness="1"
                             Padding="6"
                             Margin="0 0 0 20"/>

                <!-- Botón registrar -->
                <Button Content="Registrarse"
                        Height="40"
                        Background="#3A7BD5"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="Registrarse_Click"/>

                <!-- Volver -->
                <Button Content="Volver al login"
                        Height="40"
                        Background="#5FA8FF"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0 10 0 0"
                        Click="Volver_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>
