<UserControl x:Class="AI_TestMaker.Views.InicioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0B1020">

    <UserControl.LayoutTransform>
        <ScaleTransform x:Name="LocalZoom" ScaleX="1" ScaleY="1"/>
    </UserControl.LayoutTransform>

    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryBackground" Color="#0B1020"/>
        <SolidColorBrush x:Key="SecondaryBackground" Color="#141B2F"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#3A7BD5"/>
        <SolidColorBrush x:Key="AccentBlueLight" Color="#5FA8FF"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#B0C4DE"/>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="4"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBlueLight}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource SecondaryBackground}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="220"/>
        </Style>
    </UserControl.Resources>

    <!-- GRID PRIMARIO -->
    <Grid x:Name="OverlayRoot" Background="{StaticResource PrimaryBackground}">

        <!-- BOTÓN FIJO ARRIBA A LA DERECHA -->
        <Button x:Name="BtnTopRight"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,10,20,0"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                Padding="6"
                Panel.ZIndex="999"
                Click="BtnTopRight_Click"
                ToolTip="Perfil">

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- FOTO DE PERFIL (BOTÓN SUPERIOR DERECHA) -->
                <Border x:Name="BtnTopRightFotoBorder"
                        Height="40"
                        Width="40"
                        CornerRadius="20"
                        Background="#1F253A"
                        BorderBrush="#3A7BD5"
                        BorderThickness="1"
                        Margin="0,0,20,0"
                        ClipToBounds="True"
                        Cursor="Hand">

                    <Grid>
                        <!-- ELLIPSE que mostrará la foto mediante ImageBrush -->
                        <Ellipse x:Name="BtnTopRightEllipse"
                                 Width="40" Height="40"
                                 StrokeThickness="0"
                                 Visibility="Collapsed"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>

                        <!-- ICONO SI NO HAY FOTO -->
                        <TextBlock x:Name="BtnTopRightIcon"
                                   Text=""
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="18"
                                   Foreground="{StaticResource AccentBlueLight}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- NOMBRE -->
                <TextBlock x:Name="BtnTopRightText"
                           FontSize="16"
                           Foreground="{StaticResource AccentBlueLight}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <Button.ContextMenu>
                <ContextMenu x:Name="UserMenu"
                             Background="#141B2F"
                             Foreground="White"
                             BorderBrush="#3A7BD5"
                             BorderThickness="1">

                    <MenuItem Header="Mi perfil"
                              Foreground="White"
                              Click="MenuPerfil_Click"/>

                    <MenuItem Header="Cambiar contraseña"
                              Foreground="White"
                              Click="MenuCambiarPass_Click"/>

                    <MenuItem Header="Cerrar sesión"
                              Foreground="White"
                              Click="MenuLogout_Click"/>
                </ContextMenu>
            </Button.ContextMenu>

        </Button>


        <!-- CONTENIDO SCROLLEABLE -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
                <Grid MaxWidth="900">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- PANEL SUPERIOR -->
                    <StackPanel Grid.Row="0"
                                VerticalAlignment="Center"
                                Margin="20,10,20,30">

                        <TextBlock Text="AI TestMaker"
                                   FontSize="40"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource AccentBlueLight}"/>

                        <TextBlock Text="Generador inteligente de test para oposiciones"
                                   Margin="0,8,0,0"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextSecondary}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>

                        <Border Margin="0,30,0,0"
                                Background="{StaticResource SecondaryBackground}"
                                CornerRadius="8"
                                Padding="16">
                            <TextBlock Text="Selecciona el nivel de dificultad, el tema y la IA. El sistema generará un test adaptado a tu preparación."
                                       Foreground="{StaticResource TextSecondary}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- PANEL INFERIOR -->
                    <Border Grid.Row="1"
                            Background="{StaticResource SecondaryBackground}"
                            CornerRadius="12"
                            Padding="30"
                            Margin="20">

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                            <TextBlock Text="Empezar nuevo test"
                                       FontSize="26"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"
                                       Margin="0,0,0,20"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Nivel de dificultad"
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,10,0,4"/>

                            <Grid Width="300">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>

                                <!-- COMBOBOX -->
                                <ComboBox x:Name="DifficultyComboBox"
                                          Style="{StaticResource DarkComboBoxStyle}"
                                          SelectedIndex="1"
                                          Foreground="Black"
                                          SelectionChanged="DifficultyComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Fácil" ToolTip="20 preguntas fáciles"/>
                                    <ComboBoxItem Content="Medio" ToolTip="50 preguntas estándar"/>
                                    <ComboBoxItem Content="Difícil" ToolTip="100 preguntas difíciles"/>
                                    <ComboBoxItem Content="Personalizado" ToolTip="Número de preguntas personalizadas"/>
                                </ComboBox>

                                <!-- TEXTBOX SOLO NÚMEROS -->
                                <TextBox x:Name="CustomNumberTextBox"
                                         Grid.Column="1"
                                         Margin="10,0,0,0"
                                         VerticalContentAlignment="Center"
                                         FontSize="16"
                                         Background="White"
                                         Foreground="Black"
                                         BorderBrush="#555"
                                         BorderThickness="1"
                                         Visibility="Collapsed"
                                         PreviewTextInput="CustomNumberTextBox_PreviewTextInput"
                                         MaxLength="4"
                                         ToolTip="Ingresa el numero de preguntas"/>
                            </Grid>



                            <TextBlock Text="Tema del test"
                                       Margin="0,20,0,5"
                                       Foreground="White"
                                       FontSize="16"/>

                            <TextBox x:Name="TemaTextBox"
                                     Width="300"
                                     Height="35"
                                     FontSize="16"
                                     Padding="2"
                                     Background="White"
                                     Foreground="Black"
                                     BorderBrush="#555"
                                     BorderThickness="1"
                                     ToolTip="Ingresa un tema para el test"/>

                            <TextBlock Text="Historial de temas"
                                       Margin="0,20,0,5"
                                       Foreground="White"
                                       FontSize="16"/>

                            <!-- Historial y botón en la misma línea -->
                            <Grid HorizontalAlignment="Left" Margin="0,0,0,0" Width="304">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="18*"/>
                                    <RowDefinition Height="16*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="300"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox x:Name="HistorialComboBox"
                                          Grid.Column="0"
                                          Height="35"
                                          FontSize="16"
                                          Background="White"
                                          Foreground="Black"
                                          BorderBrush="#555"
                                          BorderThickness="1"
                                          ToolTip="Aquí puedes consultar tus tests"
                                          SelectionChanged="HistorialComboBox_SelectionChanged" Margin="2,-2,53,2" Grid.RowSpan="3"/>

                                <Button
                                        Content=""
                                        FontFamily="Segoe Fluent Icons"
                                        Height="35"
                                        Background="#AA3333"
                                        Foreground="White"
                                        Click="BorrarHistorial_Click" Margin="260,0,8,0" Grid.RowSpan="3" Grid.ColumnSpan="2"/>
                            </Grid>

                            <TextBlock Text="Selecciona la IA"
                                       Margin="0,20,0,5"
                                       Foreground="White"
                                       FontSize="16"/>

                            <Grid Width="300">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- COMBOBOX IA -->
                                <ComboBox x:Name="IAComboBox"
                                          Style="{StaticResource DarkComboBoxStyle}"
                                          Width="220"
                                          ToolTip="Selecciona tu modelo de IA"
                                          SelectionChanged="IAComboBox_SelectionChanged">
                                    <ComboBoxItem Content="DeepSeek"/>
                                    <ComboBoxItem Content="Groq"/>
                                    <ComboBoxItem Content="Gemini"/>
                                    <ComboBoxItem Content="OpenRouter"/>
                                    <ComboBoxItem x:Name="LMStudio" Content="LMStudio"/>
                                </ComboBox>

                                <!-- CHECKBOX OCULTO -->
                                <CheckBox x:Name="LMStudioCheckBox"
                                          Grid.Column="1"
                                          Margin="10,0,0,0"
                                          VerticalAlignment="Center"
                                          Foreground="White"
                                          Content="Quitar Censura"
                                          Visibility="Hidden"
                                          Checked="LMStudioCheckBox_Checked"
                                          Unchecked="LMStudioCheckBox_Unchecked"/>
                            </Grid>


                            <Button x:Name="StartTestButton"
                                    Content="Generar test"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,30,0,0"
                                    Click="StartTestButton_Click"/>

                            <Button x:Name="HistoryButton"
                                    Content="Ver tests anteriores"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,10,0,0"
                                    Click="HistoryButton_Click"/>

                        </StackPanel>
                    </Border>

                </Grid>
            </Grid>
        </ScrollViewer>

    </Grid>

</UserControl>
