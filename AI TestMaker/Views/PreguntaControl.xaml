<UserControl x:Class="AI_TestMaker.Views.PreguntaControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Margin="10">
        <!-- Enunciado -->
        <TextBlock x:Name="EnunciadoText"
                   FontSize="18"
                   FontWeight="Bold"
                   TextWrapping="Wrap"
                   Margin="0 0 0 10" 
                   Foreground="White"/>

        <!-- Opciones -->
        <StackPanel x:Name="OpcionesPanel"/>
    </StackPanel>
</UserControl>