<UserControl x:Class="AI_TestMaker.Views.PreguntaControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border CornerRadius="12"
            Background="#0F1724"
            Padding="16"
            Margin="10"
            BorderBrush="#3A3A3A"
            BorderThickness="1">

        <Border.Effect>
            <DropShadowEffect BlurRadius="12"
                              ShadowDepth="2"
                              Opacity="0.35"/>
        </Border.Effect>

        <StackPanel>
            <TextBlock x:Name="EnunciadoText"
                       FontSize="18"
                       FontWeight="Bold"
                       TextWrapping="Wrap"
                       Margin="0 0 0 12"
                       Foreground="White"/>

            <StackPanel x:Name="OpcionesPanel"
                        Margin="0 4 0 0"/>
        </StackPanel>
    </Border>
</UserControl>
