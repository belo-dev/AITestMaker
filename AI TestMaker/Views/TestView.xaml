<UserControl x:Class="AI_TestMaker.Views.TestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AI_TestMaker.Views"
             Background="#0B1020"
             FontFamily="Segoe UI"
             x:Name="RootControl">

    <UserControl.LayoutTransform>
        <ScaleTransform x:Name="LocalZoom" ScaleX="1" ScaleY="1"/>
    </UserControl.LayoutTransform>

    <UserControl.Resources>
        
        <SolidColorBrush x:Key="TiempoVerde" Color="#4CAF50"/>
        <SolidColorBrush x:Key="TiempoAmarillo" Color="#FFC107"/>
        <SolidColorBrush x:Key="TiempoRojo" Color="#F44336"/>
        <SolidColorBrush x:Key="CardBackground" Color="#121526"/>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,2"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="LayoutRoot" Margin="20">
        <!-- ContentGrid contiene todo lo que debe desenfocarse -->
        <Grid x:Name="ContentGrid">
            <Grid.Effect>
                <BlurEffect x:Name="BackgroundBlur" Radius="0"/>
            </Grid.Effect>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="*"/>
                <!-- Content -->
                <RowDefinition Height="Auto"/>
                <!-- Footer -->
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Preguntas -->
                <ColumnDefinition x:Name="NavColumn" Width="260"/>
                <!-- Navegación -->
            </Grid.ColumnDefinitions>

            <!-- Header -->
            <Border x:Name="HeaderCard" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center" >
                        <TextBlock Text="Información del Test" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="{Binding Test.Tema, StringFormat=Tema: {0}}" Foreground="#B0C4DE" Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding Test.Dificultad, StringFormat=Dificultad: {0}}" Foreground="#B0C4DE" Margin="0,2,0,0"/>
                        <TextBlock Text="{Binding Test.Fecha, StringFormat=Fecha: {0:dd/MM/yyyy HH:mm}}" Foreground="#B0C4DE" Margin="0,2,0,0"/>
                        <TextBlock Text="{Binding Test.TiempoMaximo, StringFormat=Tiempo máximo: {0}}" Foreground="#B0C4DE" Margin="0,2,0,0"/>
                    </StackPanel>

                    <Grid Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Grid Width="180" Height="180">
                            <Ellipse Fill="#0B1220" Stroke="#1F2937" StrokeThickness="8"/>
                            <Path x:Name="ArcPath" StrokeThickness="8" Stroke="#4CAF50" Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid Height="67" Width="86">
                                    <TextBlock x:Name="TxtCronometro" Text="00:00:00" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                    <TextBlock x:Name="TxtSub" Text="Tiempo restante" Foreground="#B0C4DE" FontSize="12" HorizontalAlignment="Center" Margin="0,24,0,0"/>
                                </Grid>
                            </StackPanel>

                            <Button x:Name="BtnPausa" Height="35" Click="BtnPausa_Click"
                                    ToolTip="Pausar / Reanudar" Background="#1F2937" BorderThickness="0" Cursor="Hand" VerticalAlignment="Top" Margin="70,113,70,0">
                                <Grid Width="20" Height="20">
                                    <Grid x:Name="PauseIcon" Visibility="Visible" Height="20" VerticalAlignment="Top">
                                        <Rectangle Width="6" Height="16" Fill="White" RadiusX="1" RadiusY="1" HorizontalAlignment="Left"/>
                                        <Rectangle Width="6" Height="16" Fill="White" RadiusX="1" RadiusY="1" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Path x:Name="PlayIcon" Visibility="Collapsed" Fill="White" Data="M0,0 L16,8 L0,16 Z" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                        </Grid>

                        <Button x:Name="BtnToggleNav" Width="20" Height="20" Click="BtnToggleNav_Click"
                                ToolTip="Ocultar / Mostrar navegación" Background="#1F2937" BorderThickness="0" Cursor="Hand" Margin="167,169,-7,-9">
                            <Path Data="M3,6 L21,6 M3,12 L21,12 M3,18 L21,18" Stroke="White" StrokeThickness="2" Stretch="Uniform"/>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- Preguntas -->
            <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,16,12,16">
                <StackPanel x:Name="PreguntasPanel"/>
            </ScrollViewer>

            <!-- Navegación: UniformGrid con 4 columnas dentro de ScrollViewer -->
            <Grid Grid.Row="1" Grid.Column="1" VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#0F1724" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                    <ScrollViewer x:Name="NavScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False">
                        <ItemsControl x:Name="NavItems">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Resumen -->
                <Border Grid.Row="1" Background="#0F1724" CornerRadius="10" Padding="12" Margin="0,0,0,0" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Resumen" Foreground="#B0C4DE" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtProgresoSide" Foreground="#B0C4DE" Margin="0,8,0,0" Text="Respondidas: 0/0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Footer -->
            <StackPanel x:Name="FooterPanel" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,8,0,0">
                <Button Content="Finalizar Test" Style="{StaticResource PrimaryButton}" Click="Finalizar_Click"/>
            </StackPanel>
        </Grid>

        <!-- PauseOverlay como hermano de ContentGrid: queda por encima y NO recibe blur -->
        <Grid x:Name="PauseOverlay" Visibility="Collapsed" Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Grid.ColumnSpan="2" Background="#80000000" ToolTip="Terminar intento">
            <Border Width="420" Height="180" Background="#0F1724" CornerRadius="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16">
                    <TextBlock Text="Test en pausa" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Puedes reanudar cuando quieras" Foreground="#B0C4DE" Margin="0,8,0,12" HorizontalAlignment="Center"/>
                    <Button x:Name="BtnReanudar" Content="Reanudar" Width="120" Height="36" Style="{StaticResource PrimaryButton}" Click="BtnReanudar_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
