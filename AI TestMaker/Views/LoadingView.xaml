<UserControl x:Class="AI_TestMaker.Views.LoadingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:gif="http://wpfanimatedgif.codeplex.com"
             Background="#AA0B1020">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <!-- GIF de carga -->
            <Image gif:ImageBehavior.AnimatedSource="/Views/Sandy Loading.gif"
                    Width="220"
                    Height="220"/>


            <TextBlock Text="Generando preguntas..."
                       FontSize="20"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,0"
                       Opacity="0.8"/>
        </StackPanel>
    </Grid>
</UserControl>